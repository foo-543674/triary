{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(rustfmt:*)",
      "Bash(sqlx:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(pnpm:*)",
      "Bash(biome:*)",
      "Bash(vite:*)",
      "Bash(vitest:*)",
      "Bash(tsc:*)",
      "Bash(depcruise:*)",
      "Bash(newman:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(chmod:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(find /workspaces/triary*)",
      "Bash(find .*)",
      "Bash(find backend*)",
      "Bash(find frontend*)",
      "Bash(find openapi*)",
      "Bash(find tests*)",
      "Bash(grep * /workspaces/triary*)",
      "Bash(grep * backend*)",
      "Bash(grep * frontend*)",
      "Bash(grep * openapi*)",
      "Bash(grep * tests*)",
      "Bash(grep * .)",
      "Bash(grep * ./*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(find /etc:*)",
      "Bash(find /home:*)",
      "Bash(find /proc:*)",
      "Bash(find /root:*)",
      "Bash(find /sys:*)",
      "Bash(find /usr:*)",
      "Bash(find /var:*)",
      "Bash(grep * /etc*)",
      "Bash(grep * /home*)",
      "Bash(grep * /proc*)",
      "Bash(grep * /root*)",
      "Bash(grep * /sys*)",
      "Bash(grep * /usr*)",
      "Bash(grep * /var*)"
    ]
  }
}
