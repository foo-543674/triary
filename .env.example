# triary の開発用環境変数サンプル。
# 各開発者は `cp .env.example .env` してローカルで調整する。
# 本番のシークレットは絶対にここに書かない。

# ---- MySQL (development / test 共通の認証情報) ----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=triary
MYSQL_PASSWORD=triary
MYSQL_DATABASE=triary_development
MYSQL_TEST_DATABASE=triary_test

# ---- Backend (Axum) ----
# devcontainer 内からは Docker ネットワーク経由で mysql サービス名で解決する
DATABASE_URL=mysql://triary:triary@triary-mysql:3306/triary_development
TEST_DATABASE_URL=mysql://triary:triary@triary-mysql-test:3306/triary_test
BACKEND_PORT=8080

# ---- Frontend (Vite) ----
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
