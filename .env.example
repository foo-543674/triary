# NOTE: Sample development environment file for triary.
# NOTE: Each developer should `cp .env.example .env` and tweak the copy.
# NOTE: Never put production secrets in this file.

# ---- MySQL (credentials shared between development and test) ----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=triary
MYSQL_PASSWORD=triary
MYSQL_DATABASE=triary_development
MYSQL_TEST_DATABASE=triary_test

# ---- Backend (Axum) ----
# NOTE: From inside the devcontainer the MySQL service is reachable by name
#       over the shared docker network.
DATABASE_URL=mysql://triary:triary@triary-mysql:3306/triary_development
TEST_DATABASE_URL=mysql://triary:triary@triary-mysql-test:3306/triary_test
BACKEND_PORT=8080

# ---- Frontend (Vite) ----
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080
