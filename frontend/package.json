{
  "name": "triary-frontend",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "arch:test": "depcruise --config .dependency-cruiser.cjs \"src/**/*.{ts,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "api:generate": "openapi-typescript ../openapi/openapi.yaml -o ./src/api/schema.gen.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@fast-check/vitest": "^0.4.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^25.6.0",
    "chromatic": "^16",
    "dependency-cruiser": "^16",
    "fast-check": "^4.7.0",
    "jsdom": "^29.0.2",
    "msw": "^2.13.5",
    "openapi-typescript": "^7.13.0",
    "solid-devtools": "^0.34.5",
    "storybook": "^10.3.5",
    "storybook-solidjs-vite": "^10.0.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5",
    "workbox-window": "^7.4.0"
  },
  "dependencies": {
    "@solidjs/router": "^0.16.1",
    "@tanstack/solid-query": "^5.99.0",
    "openapi-fetch": "^0.17.0",
    "solid-js": "^1.9.12"
  },
  "pnpm": {
    "overrides": {
      "seroval": ">=1.4.1",
      "tar": ">=7.5.11",
      "rollup": ">=4.59.0",
      "picomatch": ">=4.0.4",
      "yaml": ">=2.8.3",
      "serialize-javascript": ">=7.0.5"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
